# MQTT
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC=#
MQTT_USERNAME=
MQTT_PASSWORD=

# 파일 PQ
PQ_PATH=./pq/queue.jsonl
PQ_SIZE_LIMIT_ENABLED=true   # 용량 제한 on/off
PQ_MAX_MB=100                 # PQ_SIZE_LIMIT_ENABLED=true 일 때만 적용

# DB
# DB_TYPE: postgresql | mssql | oracle
DB_TYPE=postgresql

## PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sensor_db
DB_TABLE_NAME=sensor_data
DB_USER=postgres
DB_PASSWORD=password

## MSSQL (DB_TYPE=mssql 일 때)
# DB_HOST=localhost
# DB_PORT=1433
# DB_NAME=sensor_db
# DB_USER=sa
# DB_PASSWORD=password
# MSSQL_DRIVER=ODBC Driver 17 for SQL Server

## Oracle (DB_TYPE=oracle 일 때)
# DB_HOST=localhost
# DB_PORT=1521
# DB_NAME=ORCLPDB1   # 서비스명 또는 SID
# DB_USER=system
# DB_PASSWORD=password

# Loader
BATCH_SIZE=500
POLL_INTERVAL=5

# 로그
LOG_LEVEL=INFO

# 페이로드 매핑
MAPPING_PATH=./mapping.json

# 로그
LOG_DIR=./logs
LOG_MAX_MB=100        # 파일 하나당 최대 용량 (MB)
LOG_MAX_FILES=30      # 최대 보관 파일 수 (초과 시 오래된 것부터 삭제)