# MQTT
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC=#
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_RETRY_INTERVAL=5   # 연결 실패 시 재시도 대기(초)
MQTT_MAX_RETRIES=0      # 0 = 무한 재시도. N>0 이면 N회 연속 실패 시 collector 중단

# 파일 PQ
PQ_PATH=./pq/queue.jsonl
PQ_SIZE_LIMIT_ENABLED=true   # 용량 제한 on/off
PQ_MAX_MB=100                 # PQ_SIZE_LIMIT_ENABLED=true 일 때만 적용 (최소 1MB로 강제 보정됨)

# DB
# DB_TYPE: postgresql | mssql | oracle
DB_TYPE=postgresql

## PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sensor_db
DB_TABLE_NAME=sensor_data
DB_USER=postgres
DB_PASSWORD=password

## MSSQL (DB_TYPE=mssql 일 때)
# DB_HOST=localhost
# DB_PORT=1433
# DB_NAME=sensor_db
# DB_USER=sa
# DB_PASSWORD=password
# MSSQL_DRIVER=ODBC Driver 17 for SQL Server

## Oracle (DB_TYPE=oracle 일 때)
# DB_HOST=localhost
# DB_PORT=1521
# DB_NAME=ORCLPDB1   # 서비스명 또는 SID
# DB_USER=system
# DB_PASSWORD=password

# Loader
BATCH_SIZE=500
POLL_INTERVAL=5
LOADER_RETRY_INTERVAL=5   # DB 연결/재연결 실패 시 재시도 대기(초)
LOADER_MAX_RETRIES=0      # 0 = 무한 재시도(운영 권장). N>0 이면 N회 연속 실패 시 loader 중단(데이터는 PQ에 안전 보관)

# 로그
LOG_LEVEL=INFO

# 페이로드 매핑
MAPPING_PATH=./mapping.json

# 로그
LOG_DIR=./logs
LOG_MAX_MB=100        # 파일 하나당 최대 용량 (MB)
LOG_MAX_FILES=30      # 최대 보관 파일 수 (초과 시 오래된 것부터 삭제)